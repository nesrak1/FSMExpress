<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dlg="using:FSMExpress.Silksong.ViewModels.Dialogs"
             xmlns:map="using:FSMExpress.Silksong.Controls.MapSelector"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
             x:Class="FSMExpress.Silksong.Views.Dialogs.MapSelectorView"
             x:DataType="dlg:MapSelectorViewModel">
  <Grid Margin="10,10,10,10">
    <Grid RowDefinitions="*,Auto"
          HorizontalAlignment="Stretch">
      <map:MapControl MapCol="{Binding MapCol}" SelectedLevel="{Binding SelectedLevel}" />
      <Grid Grid.Row="1" ColumnDefinitions="*,*">
        <Button Grid.Column="0" Command="{Binding PickOk}">Ok</Button>
        <Button Grid.Column="1" Command="{Binding PickCancel}">Cancel</Button>
      </Grid>
    </Grid>
  </Grid>
</UserControl>